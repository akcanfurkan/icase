# iCase Server Configuration

# Google Gemini API Key (optional — server-level fallback)
# Users can also enter their own key via Settings page
# Get yours free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# JWT Secret (REQUIRED in production — use a long random string)
# Example: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# Server port (default: 3001)
PORT=3001

# Node environment (set to 'production' for deployment)
NODE_ENV=production

# CORS origin (optional — default allows all origins)
# Set to your frontend URL for tighter security, e.g. https://icase.example.com
# CORS_ORIGIN=https://icase.example.com
